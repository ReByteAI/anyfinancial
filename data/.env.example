# Optional AnyFinancial CLI overrides.
#
# In a Rebyte VM/workspace, leave these unset. The CLI reads:
#   1. AUTH_TOKEN env var
#   2. `rebyte-auth`
#   3. /home/user/.rebyte.ai/auth.json
#
# API_URL defaults to the sandbox relay_url from auth.json, then
# https://api.rebyte.ai.

# API_URL=https://api.rebyte.ai
# AUTH_TOKEN=<sandbox bearer token>
